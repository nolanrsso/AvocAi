# ─── AvocAI — exemple de configuration .env ───────────
# Copier ce fichier en .env et remplir les valeurs

# JWT (obligatoire, min 32 caractères en prod)
JWT_SECRET=changez-moi-en-32-caracteres-minimum

# OpenAI (obligatoire pour le chat et la génération de documents)
OPENAI_API_KEY=sk-...

# Stripe (obligatoire pour les paiements)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google OAuth (optionnel — Sign in with Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APP_URL=http://localhost:3000

# ─── SMTP (envoi email vérification + alertes) ───────
# Exemples :
#   Gmail : SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
#   OVH   : SMTP_HOST=ssl0.ovh.net, SMTP_PORT=465, SMTP_SECURE=true
#   Brevo : SMTP_HOST=smtp-relay.brevo.com, SMTP_PORT=587
#   Resend : SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_SECURE=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=AvocAI <noreply@avocai.fr>

# CORS (en prod : ton domaine ; en dev : laisser localhost)
ALLOWED_ORIGINS=http://localhost:3000

# Production (NODE_ENV=production active HSTS + retire devCode des réponses)
NODE_ENV=development
